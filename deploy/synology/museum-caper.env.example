# Copy this file to .env beside docker-compose.yml on the NAS.
#
# IMAGE_NAME and TAG select the image loaded into Synology Container Manager.
IMAGE_NAME=museum-caper
TAG=latest

# Host port exposed on the NAS. Use http://NAS_HOST_OR_IP:4000 by default.
HOST_PORT=4000

# Phoenix runtime settings.
PHX_HOST=NAS_HOST_OR_IP
PHX_URL_SCHEME=http
PHX_URL_PORT=4000
# Use /museum_caper when deploying behind a path-based reverse proxy.
PHX_URL_PATH=/
# Optional comma-separated browser origins allowed to connect LiveView.
# Use this when you want both LAN and DuckDNS URLs to work.
PHX_CHECK_ORIGIN=http://NAS_HOST_OR_IP:4000
PHX_SERVER=true
PORT=4000

# Generate a real value with:
#   mix phx.gen.secret
# or:
#   openssl rand -base64 64 | tr -d '\n'
SECRET_KEY_BASE=replace-me-with-a-generated-secret
